{
  "scripts": {
    "_prettier:xml": "prettier --plugin=@prettier/plugin-xml **/*.xml",
    "prettier:xml:check": "npm run _prettier:xml -- --check",
    "prettier:xml:write": "npm run _prettier:xml -- --write",
    "_prettier": "prettier .",
    "prettier:check": "npm run _prettier -- --check",
    "postprettier:check": "npm run prettier:xml:check",
    "prettier:write": "npm run _prettier -- --write",
    "postprettier:write": "npm run prettier:xml:write",
    "lint": "npm run prettier:check",
    "format": "npm run prettier:write",
    "postformat": "npm run lint",
    "test": "exit 0"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "prettier": "^3.8.3"
  }
}
